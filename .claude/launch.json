{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "flutter-web",
      "runtimeExecutable": "cmd",
      "runtimeArgs": [
        "/c",
        "flutter",
        "run",
        "-d",
        "web-server",
        "--web-port",
        "8080",
        "--web-hostname",
        "0.0.0.0"
      ],
      "port": 8080
    },
    {
      "name": "build-runner-watch",
      "runtimeExecutable": "cmd",
      "runtimeArgs": [
        "/c",
        "flutter",
        "pub",
        "run",
        "build_runner",
        "watch",
        "--delete-conflicting-outputs"
      ],
      "port": 0
    }
  ]
}
